# ── MAE WELLNESS CLUB — Environment Configuration Template
# Duplicate this file as '.env' and fill in your keys.
# ⚠️ NEVER commit '.env' with real secrets to version control.

# ── Supabase Configuration
# Obtain in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your_project_id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# ── Stripe Configuration (Live or Test Mode)
# Prefixed with pk_live_ / sk_live_ for production, or pk_test_ / sk_test_ for staging.
VITE_STRIPE_PUBLISHABLE_KEY=pk_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_your_stripe_secret_key

# ── Stripe Webhook Secret
# Obtain via Stripe CLI local trigger or Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Supabase Service Role Key (Admin Permissions Bypass)
# Obtain in: Supabase Dashboard → Settings → API → service_role (secret)
# ⚠️ ONLY needed for running local scripts (e.g. export-users.mjs, rpc-tests.mjs).
# Never expose this key in public client bundles.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret_key
